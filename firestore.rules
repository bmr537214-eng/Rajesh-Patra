rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Global Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isEmailVerified() && request.auth.uid == userId;
    }

    // 2. Validation Blueprints (Anti-Update-Gap)
    function isValidUser(data) {
      return data.personality is string 
          && data.personality.size() <= 32;
    }

    function isValidMemory(data, userId) {
      return data.id is string && data.id.size() <= 128
          && data.fact is string && data.fact.size() <= 1024
          && data.userId == userId
          && data.category is string && data.category.size() <= 64;
    }

    // Match blocks
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create, update: if isOwner(userId) && isValidUser(request.resource.data);
    }

    match /users/{userId}/memories/{memoryId} {
      allow list, get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidMemory(request.resource.data, userId);
      allow update: if isOwner(userId) && isValidMemory(request.resource.data, userId);
      allow delete: if isOwner(userId);
    }
  }
}
